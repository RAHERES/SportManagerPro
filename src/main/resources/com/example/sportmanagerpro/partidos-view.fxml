<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.PartidoController">

    <top>
        <Label text="Gestión de Partidos"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-padding: 20;" />
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <GridPane hgap="10" vgap="10">

                <Label text="Competencia:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <ComboBox fx:id="cmbCompetencia" prefWidth="260"
                          GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Categoría:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <ComboBox fx:id="cmbCategoria" prefWidth="260"
                          GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Fecha:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <DatePicker fx:id="dpFecha" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Rival:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="txtRival" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                <Label text="Sede:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <TextField fx:id="txtSede" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                <Label text="Fase:" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <ComboBox fx:id="cmbFase" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                <Label text="Marcador a favor:" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                <TextField fx:id="txtMarcadorFavor" GridPane.rowIndex="2" GridPane.columnIndex="3" />

                <Label text="Marcador en contra:" GridPane.rowIndex="3" GridPane.columnIndex="2" />
                <TextField fx:id="txtMarcadorContra" GridPane.rowIndex="3" GridPane.columnIndex="3" />

                <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextArea fx:id="txtObservaciones" prefRowCount="3"
                          GridPane.rowIndex="4" GridPane.columnIndex="1"
                          GridPane.columnSpan="3" />
            </GridPane>

            <HBox spacing="10">
                <Button text="Nuevo" onAction="#limpiarFormulario" />
                <Button text="Guardar" onAction="#guardarPartido" />
                <Button text="Actualizar" onAction="#actualizarPartido" />
            </HBox>

            <TableView fx:id="tablaPartidos" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="110" />
                    <TableColumn fx:id="colRival" text="Rival" prefWidth="180" />
                    <TableColumn fx:id="colCategoria" text="Categoría ID" prefWidth="100" />
                    <TableColumn fx:id="colMarcador" text="Marcador" prefWidth="100" />
                    <TableColumn fx:id="colResultado" text="Resultado" prefWidth="120" />
                    <TableColumn fx:id="colFase" text="Fase" prefWidth="130" />
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>