<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ComboBox?>
<BorderPane
        xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.MainController">
    <left>
        <VBox spacing="10" prefWidth="220" style="-fx-padding: 20; -fx-background-color: #1f2937;">
            <Label text="SportManager Pro" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />

            <Button text="Inicio"
                    maxWidth="Infinity"
                    onAction="#mostrarDashboard" />
            <Button text="Categorías" maxWidth="Infinity" onAction="#mostrarCategorias" />
            <Button text="Deportistas" maxWidth="Infinity" onAction="#mostrarDeportistas" />
            <Button text="Entrenamientos" maxWidth="Infinity" onAction="#mostrarEntrenamientos" />
            <Button text="Asistencia"
                    maxWidth="Infinity"
                    onAction="#mostrarAsistencia" />
            <Button text="Evaluaciones"
                    maxWidth="Infinity"
                    onAction="#mostrarEvaluaciones" />
            <Button text="Competencias"
                    maxWidth="Infinity"
                    onAction="#mostrarCompetencias" />
            <Button text="Partidos"
                    maxWidth="Infinity"
                    onAction="#mostrarPartidos" />
            <Button text="Reportes" maxWidth="Infinity" />
            <Button text="Estadísticas"
                    maxWidth="Infinity"
                    onAction="#mostrarEstadisticasPartido" />
            <Button text="Historial"
                    maxWidth="Infinity"
                    onAction="#mostrarHistorialDeportista" />

            <Button text="Lesiones"
                    maxWidth="Infinity"
                    onAction="#mostrarLesiones" />
            <Button text="Observaciones"
                    maxWidth="Infinity"
                    onAction="#mostrarObservaciones" />
            <Button text="Reporte categoría"
                    maxWidth="Infinity"
                    onAction="#mostrarReporteCategoria" />

            <Button text="Planificación"
                    onAction="#abrirPlanGrafico"/>
        </VBox>




    </left>

    <center>
        <StackPane fx:id="contentPane">
            <VBox alignment="CENTER" spacing="15">
                <Label text="Bienvenido a SportManager Pro"
                       style="-fx-font-size: 28; -fx-font-weight: bold;" />
                <Label text="Sistema de gestión de deportistas, entrenamientos y competencias"
                       style="-fx-font-size: 16;" />
            </VBox>
        </StackPane>
    </center>
</BorderPane>
