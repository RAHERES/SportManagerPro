<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.CompetenciaController">

    <top>
        <Label text="Gestión de Competencias"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-padding: 20;" />
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <GridPane hgap="10" vgap="10">

                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Tipo:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <ComboBox fx:id="cmbTipo" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Sede:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="txtSede" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Fecha inicio:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <DatePicker fx:id="dpFechaInicio" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                <Label text="Fecha fin:" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <DatePicker fx:id="dpFechaFin" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                <Label text="Descripción:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextArea fx:id="txtDescripcion" prefRowCount="3"
                          GridPane.rowIndex="3" GridPane.columnIndex="1"
                          GridPane.columnSpan="3" />

                <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextArea fx:id="txtObservaciones" prefRowCount="3"
                          GridPane.rowIndex="4" GridPane.columnIndex="1"
                          GridPane.columnSpan="3" />
            </GridPane>

            <HBox spacing="10">
                <Button text="Nuevo" onAction="#limpiarFormulario" />
                <Button text="Guardar" onAction="#guardarCompetencia" />
                <Button text="Actualizar" onAction="#actualizarCompetencia" />
            </HBox>

            <TableView fx:id="tablaCompetencias" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="220" />
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="130" />
                    <TableColumn fx:id="colSede" text="Sede" prefWidth="180" />
                    <TableColumn fx:id="colFechaInicio" text="Inicio" prefWidth="110" />
                    <TableColumn fx:id="colFechaFin" text="Fin" prefWidth="110" />
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>
