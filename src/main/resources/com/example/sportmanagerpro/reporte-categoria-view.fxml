<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>



<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.ReporteCategoriaController">

    <top>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="Reporte por Categoría"
                   style="-fx-font-size: 24; -fx-font-weight: bold;" />

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Categoría:" />

                <ComboBox fx:id="cmbCategoria"
                          prefWidth="300"
                          onAction="#cargarReporte" />

                <Button text="Actualizar"
                        onAction="#cargarReporte" />
            </HBox>
        </VBox>
    </top>

    <center>
        <GridPane hgap="15" vgap="15" style="-fx-padding: 20;">

            <VBox styleClass="dashboard-card" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <Label text="Total deportistas" />
                <Label fx:id="lblTotalDeportistas" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <Label text="Deportistas activas" />
                <Label fx:id="lblDeportistasActivas" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="0" GridPane.columnIndex="2">
                <Label text="Entrenamientos" />
                <Label fx:id="lblEntrenamientos" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <Label text="Asistencia" />
                <Label fx:id="lblAsistencia" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <Label text="Partidos" />
                <Label fx:id="lblPartidos" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="1" GridPane.columnIndex="2">
                <Label text="Evaluaciones físicas" />
                <Label fx:id="lblEvaluaciones" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="2" GridPane.columnIndex="0">
                <Label text="Victorias" />
                <Label fx:id="lblVictorias" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="2" GridPane.columnIndex="1">
                <Label text="Empates" />
                <Label fx:id="lblEmpates" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="2" GridPane.columnIndex="2">
                <Label text="Derrotas" />
                <Label fx:id="lblDerrotas" styleClass="dashboard-number" />
            </VBox>

            <VBox styleClass="dashboard-card" GridPane.rowIndex="3" GridPane.columnIndex="0">
                <Label text="Lesiones activas" />
                <Label fx:id="lblLesionesActivas" styleClass="dashboard-number" />
            </VBox>

        </GridPane>
    </center>

</BorderPane>