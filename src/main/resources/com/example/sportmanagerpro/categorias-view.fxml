<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.CategoriaController">

    <top>
        <Label text="Gestión de Categorías"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-padding: 20;" />
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <GridPane hgap="10" vgap="10">
                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Rango de edad:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="txtRangoEdad" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Descripción:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextArea fx:id="txtDescripcion" prefRowCount="3" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <CheckBox fx:id="chkActiva" text="Categoría activa" selected="true"
                          GridPane.rowIndex="3" GridPane.columnIndex="1" />
            </GridPane>

            <HBox spacing="10">
                <Button text="Nuevo" onAction="#limpiarFormulario" />
                <Button text="Guardar" onAction="#guardarCategoria" />
                <Button text="Actualizar" onAction="#actualizarCategoria" />
                <Button text="Desactivar" onAction="#desactivarCategoria" />
            </HBox>

            <TableView fx:id="tablaCategorias" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180" />
                    <TableColumn fx:id="colRangoEdad" text="Rango de edad" prefWidth="150" />
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="300" />
                    <TableColumn fx:id="colActiva" text="Activa" prefWidth="100" />
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>