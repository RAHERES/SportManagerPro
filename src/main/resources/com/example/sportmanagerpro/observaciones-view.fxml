<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sportmanagerpro.controllers.ObservacionDeportivaController">

    <top>
        <Label text="Observaciones Deportivas"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-padding: 20;" />
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <GridPane hgap="10" vgap="10">

                <Label text="Deportista:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <ComboBox fx:id="cmbDeportista" prefWidth="300"
                          GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <DatePicker fx:id="dpFecha" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Tipo:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <ComboBox fx:id="cmbTipo" prefWidth="300"
                          GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Observación:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextArea fx:id="txtObservacion"
                          prefRowCount="5"
                          prefWidth="500"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1" />

            </GridPane>

            <HBox spacing="10">
                <Button text="Nuevo" onAction="#limpiarFormulario" />
                <Button text="Guardar" onAction="#guardarObservacion" />
                <Button text="Actualizar" onAction="#actualizarObservacion" />
            </HBox>

            <TableView fx:id="tablaObservaciones" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="110" />
                    <TableColumn fx:id="colDeportista" text="ID deportista" prefWidth="110" />
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150" />
                    <TableColumn fx:id="colObservacion" text="Observación" prefWidth="500" />
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>